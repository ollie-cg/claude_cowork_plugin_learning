{
  "version": "1.0",
  "conventions": {
    "test_prefix": "[TEST]",
    "teardown_strategy": "Search all object types for records with [TEST] in name fields and delete them",
    "execute_method": "Isolated Claude session with skill loaded"
  },
  "processes": [
    {
      "id": "buyer.onboard",
      "category": "buyer_management",
      "name": "Create a company, contact, and buyer deal",
      "trigger": "Operator needs to set up a new buyer with a contact and a deal in the Buyer Deal Pipeline",
      "prompt": "Create a new company called [TEST] Greenleaf Grocers. They are a retail business based in London, United Kingdom. Their domain is testgreenleafgrocers.com and phone number is 44 2071234567. Then create a contact at that company called Tom Baker. He is a Purchasing Manager in the Buying department, based in London, United Kingdom. His email is tom.baker@testgreenleafgrocers.com and his phone number is 44 2079876543. Set him as a lead. Make sure he is associated to the company. Then create a buyer deal called '[TEST] Greenleaf Grocers - New Deal' in the Buyer Deal Pipeline at the Discovery stage. Set the customer profile to 'High Street'. Make sure the deal is associated to the company. Associate the deal with the MOJU client service so that a Brand record is auto-created.",
      "actions": [
        {
          "id": "create_company",
          "description": "Create the buyer company with provided properties",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/companies/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "domain",
                      "operator": "EQ",
                      "value": "testgreenleafgrocers.com"
                    }
                  ]
                }
              ],
              "properties": [
                "name",
                "domain",
                "city",
                "country",
                "phone",
                "createdate"
              ]
            },
            "capture": {
              "company_id": "$.results[0].id"
            },
            "assertions": [
              { "field": "name", "operator": "contains", "value": "Greenleaf Grocers" },
              { "field": "domain", "operator": "eq", "value": "testgreenleafgrocers.com" },
              { "field": "city", "operator": "eq", "value": "London" },
              { "field": "country", "operator": "eq", "value": "United Kingdom" }
            ]
          }
        },
        {
          "id": "create_contact_and_associate",
          "description": "Create the contact with provided properties and associate to the company",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/contacts/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "email",
                      "operator": "EQ",
                      "value": "tom.baker@testgreenleafgrocers.com"
                    }
                  ]
                }
              ],
              "properties": [
                "firstname",
                "lastname",
                "email",
                "jobtitle",
                "department",
                "phone",
                "city",
                "country",
                "lifecyclestage",
                "createdate"
              ]
            },
            "capture": {
              "contact_id": "$.results[0].id"
            },
            "assertions": [
              { "field": "firstname", "operator": "eq", "value": "Tom" },
              { "field": "lastname", "operator": "eq", "value": "Baker" },
              { "field": "email", "operator": "eq", "value": "tom.baker@testgreenleafgrocers.com" },
              { "field": "jobtitle", "operator": "eq", "value": "Purchasing Manager" },
              { "field": "department", "operator": "eq", "value": "Buying" },
              { "field": "city", "operator": "eq", "value": "London" },
              { "field": "country", "operator": "eq", "value": "United Kingdom" },
              { "field": "lifecyclestage", "operator": "eq", "value": "lead" },
              {
                "field": "associations",
                "operator": "associated_to",
                "object_type": "companies",
                "value": "{company_id}"
              }
            ]
          }
        },
        {
          "id": "create_deal_and_associate",
          "description": "Create a buyer deal in the Buyer Deal Pipeline at Discovery and associate to the company",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/deals/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "dealname",
                      "operator": "EQ",
                      "value": "[TEST] Greenleaf Grocers - New Deal"
                    }
                  ]
                }
              ],
              "properties": [
                "dealname",
                "pipeline",
                "dealstage",
                "customer_profile",
                "buyer",
                "createdate"
              ],
              "sorts": [{"propertyName": "createdate", "direction": "DESCENDING"}]
            },
            "capture": {
              "deal_id": "$.results[0].id"
            },
            "assertions": [
              { "field": "dealname", "operator": "eq", "value": "[TEST] Greenleaf Grocers - New Deal" },
              { "field": "pipeline", "operator": "eq", "value": "2760762586" },
              { "field": "dealstage", "operator": "eq", "value": "4443390193" },
              { "field": "customer_profile", "operator": "eq", "value": "High Street" },
              { "field": "buyer", "operator": "contains", "value": "Greenleaf Grocers" },
              {
                "field": "associations",
                "operator": "associated_to",
                "object_type": "companies",
                "value": "{company_id}"
              }
            ]
          }
        },
        {
          "id": "verify_brand_auto_created",
          "description": "Verify a Brand record was auto-created by the workflow with correct client_name_sync",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/0-970/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "buyer_name",
                      "operator": "CONTAINS_TOKEN",
                      "value": "Greenleaf"
                    }
                  ]
                }
              ],
              "properties": [
                "buyer_name",
                "client_name_sync",
                "hs_pipeline",
                "hs_pipeline_stage",
                "createdate"
              ],
              "sorts": [{"propertyName": "hs_createdate", "direction": "DESCENDING"}]
            },
            "capture": {
              "brand_id": "$.results[0].id"
            },
            "assertions": [
              { "field": "buyer_name", "operator": "contains", "value": "Greenleaf Grocers" },
              { "field": "client_name_sync", "operator": "eq", "value": "MOJU" },
              {
                "field": "associations",
                "operator": "associated_to",
                "object_type": "deals",
                "value": "{deal_id}"
              }
            ]
          }
        }
      ],
      "teardown": {
        "description": "Remove test brand, deal, contact, and company (brand first, then parent records)",
        "api_calls": [
          {
            "id": "delete_brand",
            "method": "DELETE",
            "endpoint": "/crm/v3/objects/0-970/{brand_id}"
          },
          {
            "id": "delete_deal",
            "method": "DELETE",
            "endpoint": "/crm/v3/objects/deals/{deal_id}"
          },
          {
            "id": "delete_contact",
            "method": "DELETE",
            "endpoint": "/crm/v3/objects/contacts/{contact_id}"
          },
          {
            "id": "delete_company",
            "method": "DELETE",
            "endpoint": "/crm/v3/objects/companies/{company_id}"
          }
        ]
      }
    },
    {
      "id": "buyer.onboard_with_engagements",
      "category": "buyer_management",
      "name": "Create a company, deal, note, and call log",
      "trigger": "Operator needs to set up a new buyer deal and log initial engagement activity (meeting notes and a follow-up call)",
      "prompt": "Create a new company called '[TEST] Riverside Retail Group'. They are a grocery retailer based in Manchester, United Kingdom. Their domain is testriversideretail.com.\n\nThen create a buyer deal called '[TEST] Riverside Retail Group — Snack Range Pitch' in the Buyer Deal Pipeline at the Discovery stage. Associate the deal to the company. Associate the deal with the Love Corn client service so that a Brand record is auto-created.\n\nThen add a note to the deal. The note should contain:\n\"[TEST] Initial meeting notes — Riverside buyer (Jane Cooper, Head of Ambient) wants to see our full protein bar range. Key requirements: minimum 30% retail margin, must have Nutri-Score on pack, 5 working day delivery lead time. Interested in 3 SKUs initially with option to expand to full range if velocity targets are met in first 12 weeks. Next step: send formal proposal by end of week.\"\n\nThen log an outbound call on the deal. The call title should be '[TEST] Follow-up call with Jane Cooper — Riverside'. The call should be marked as completed with a duration of 15 minutes. The call body should contain:\n\"[TEST] Call summary — Spoke with Jane Cooper to follow up on proposal. She confirmed the September gondola reset is the target window. Pricing feedback: our £2.09 RSP works for the 45g bars but she wants £1.89 for the 30g snack bites. She will send planogram dimensions by Thursday. Action items: (1) Revise pricing for 30g range (2) Send updated packaging mockups (3) Confirm MOQs for half-case shippers.\"",
      "actions": [
        {
          "id": "create_company",
          "description": "Create the buyer company",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/companies/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "domain",
                      "operator": "EQ",
                      "value": "testriversideretail.com"
                    }
                  ]
                }
              ],
              "properties": [
                "name",
                "domain",
                "city",
                "country",
                "createdate"
              ]
            },
            "capture": {
              "company_id": "$.results[0].id"
            },
            "assertions": [
              { "field": "name", "operator": "contains", "value": "Riverside Retail Group" },
              { "field": "domain", "operator": "eq", "value": "testriversideretail.com" },
              { "field": "city", "operator": "eq", "value": "Manchester" },
              { "field": "country", "operator": "eq", "value": "United Kingdom" }
            ]
          }
        },
        {
          "id": "create_deal_and_associate",
          "description": "Create a buyer deal in the Buyer Deal Pipeline at Discovery and associate to the company",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/deals/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "dealname",
                      "operator": "CONTAINS_TOKEN",
                      "value": "Riverside"
                    }
                  ]
                }
              ],
              "properties": [
                "dealname",
                "pipeline",
                "dealstage",
                "createdate"
              ],
              "sorts": [{"propertyName": "createdate", "direction": "DESCENDING"}]
            },
            "capture": {
              "deal_id": "$.results[0].id"
            },
            "assertions": [
              { "field": "dealname", "operator": "contains", "value": "Riverside Retail Group" },
              { "field": "pipeline", "operator": "eq", "value": "2760762586" },
              { "field": "dealstage", "operator": "eq", "value": "4443390193" },
              {
                "field": "associations",
                "operator": "associated_to",
                "object_type": "companies",
                "value": "{company_id}"
              }
            ]
          }
        },
        {
          "id": "create_note_on_deal",
          "description": "Create a note with meeting details and associate it to the deal",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/notes/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "hs_note_body",
                      "operator": "CONTAINS_TOKEN",
                      "value": "Riverside"
                    }
                  ]
                }
              ],
              "properties": [
                "hs_note_body",
                "hs_timestamp",
                "createdate"
              ],
              "sorts": [{"propertyName": "hs_createdate", "direction": "DESCENDING"}]
            },
            "capture": {
              "note_id": "$.results[0].id"
            },
            "assertions": [
              { "field": "hs_note_body", "operator": "contains", "value": "protein bar range" },
              { "field": "hs_note_body", "operator": "contains", "value": "Nutri-Score" },
              {
                "field": "associations",
                "operator": "associated_to",
                "object_type": "deals",
                "value": "{deal_id}"
              }
            ]
          }
        },
        {
          "id": "create_call_on_deal",
          "description": "Log a completed outbound call with transcript and associate it to the deal",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/calls/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "hs_call_title",
                      "operator": "CONTAINS_TOKEN",
                      "value": "Riverside"
                    }
                  ]
                }
              ],
              "properties": [
                "hs_call_title",
                "hs_call_body",
                "hs_call_direction",
                "hs_call_status",
                "hs_call_duration",
                "createdate"
              ],
              "sorts": [{"propertyName": "hs_createdate", "direction": "DESCENDING"}]
            },
            "capture": {
              "call_id": "$.results[0].id"
            },
            "assertions": [
              { "field": "hs_call_title", "operator": "contains", "value": "Riverside" },
              { "field": "hs_call_body", "operator": "contains", "value": "September gondola reset" },
              { "field": "hs_call_direction", "operator": "eq", "value": "OUTBOUND" },
              { "field": "hs_call_status", "operator": "eq", "value": "COMPLETED" },
              {
                "field": "associations",
                "operator": "associated_to",
                "object_type": "deals",
                "value": "{deal_id}"
              }
            ]
          }
        },
        {
          "id": "verify_brand_auto_created",
          "description": "Verify a Brand record was auto-created by the workflow with correct client_name_sync",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/0-970/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "buyer_name",
                      "operator": "CONTAINS_TOKEN",
                      "value": "Riverside"
                    }
                  ]
                }
              ],
              "properties": [
                "buyer_name",
                "client_name_sync",
                "hs_pipeline",
                "hs_pipeline_stage",
                "createdate"
              ],
              "sorts": [{"propertyName": "hs_createdate", "direction": "DESCENDING"}]
            },
            "capture": {
              "brand_id": "$.results[0].id"
            },
            "assertions": [
              { "field": "buyer_name", "operator": "contains", "value": "Riverside Retail Group" },
              { "field": "client_name_sync", "operator": "eq", "value": "Love Corn" },
              {
                "field": "associations",
                "operator": "associated_to",
                "object_type": "deals",
                "value": "{deal_id}"
              }
            ]
          }
        }
      ],
      "teardown": {
        "description": "Remove test brand, call, note, deal, and company (brand + engagements first, then parent records)",
        "api_calls": [
          {
            "id": "delete_brand",
            "method": "DELETE",
            "endpoint": "/crm/v3/objects/0-970/{brand_id}"
          },
          {
            "id": "delete_call",
            "method": "DELETE",
            "endpoint": "/crm/v3/objects/calls/{call_id}"
          },
          {
            "id": "delete_note",
            "method": "DELETE",
            "endpoint": "/crm/v3/objects/notes/{note_id}"
          },
          {
            "id": "delete_deal",
            "method": "DELETE",
            "endpoint": "/crm/v3/objects/deals/{deal_id}"
          },
          {
            "id": "delete_company",
            "method": "DELETE",
            "endpoint": "/crm/v3/objects/companies/{company_id}"
          }
        ]
      }
    },
    {
      "id": "buyer.pipeline_progression",
      "category": "buyer_management",
      "name": "Create a deal and move it through every stage of the Buyer Deal Pipeline",
      "trigger": "Operator needs to progress a buyer deal through the full pipeline from Discovery to Won",
      "prompt": "Create a new company called '[TEST] Northfield Convenience Stores'. They are a convenience retailer based in Leeds, United Kingdom. Their domain is testnorthfieldstores.com.\n\nThen create a buyer deal called '[TEST] Northfield — Full Pipeline Run' in the Buyer Deal Pipeline at the Discovery stage. Associate the deal to the company. Associate the deal with the GLUG! client service so that a Brand record is auto-created.\n\nNow move the deal through every open stage of the Buyer Deal Pipeline in order:\n1. Move it to Follow Up\n2. Move it to Feedback Pending\n3. Move it to Feedback Received\n4. Move it to Proposal\n5. Move it to Proposal Feedback Pending\n6. Finally, move it to Won\n\nAfter each move, confirm the deal is at the correct stage before moving to the next one. At the end, the deal should be at the Won stage and marked as closed-won.",
      "actions": [
        {
          "id": "create_company",
          "description": "Create the buyer company",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/companies/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "domain",
                      "operator": "EQ",
                      "value": "testnorthfieldstores.com"
                    }
                  ]
                }
              ],
              "properties": [
                "name",
                "domain",
                "city",
                "country",
                "createdate"
              ]
            },
            "capture": {
              "company_id": "$.results[0].id"
            },
            "assertions": [
              { "field": "name", "operator": "contains", "value": "Northfield Convenience Stores" },
              { "field": "domain", "operator": "eq", "value": "testnorthfieldstores.com" },
              { "field": "city", "operator": "eq", "value": "Leeds" },
              { "field": "country", "operator": "eq", "value": "United Kingdom" }
            ]
          }
        },
        {
          "id": "create_deal_and_associate",
          "description": "Create a buyer deal in the Buyer Deal Pipeline and associate to the company",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/deals/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "dealname",
                      "operator": "CONTAINS_TOKEN",
                      "value": "Northfield"
                    }
                  ]
                }
              ],
              "properties": [
                "dealname",
                "pipeline",
                "createdate"
              ],
              "sorts": [{"propertyName": "createdate", "direction": "DESCENDING"}]
            },
            "capture": {
              "deal_id": "$.results[0].id"
            },
            "assertions": [
              { "field": "dealname", "operator": "contains", "value": "Northfield" },
              { "field": "pipeline", "operator": "eq", "value": "2760762586" },
              {
                "field": "associations",
                "operator": "associated_to",
                "object_type": "companies",
                "value": "{company_id}"
              }
            ]
          }
        },
        {
          "id": "verify_final_stage_is_won",
          "description": "Verify the deal ended at Won and is marked closed-won",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/deals/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "dealname",
                      "operator": "CONTAINS_TOKEN",
                      "value": "Northfield"
                    }
                  ]
                }
              ],
              "properties": [
                "dealname",
                "dealstage",
                "hs_is_closed",
                "hs_is_closed_won",
                "createdate"
              ],
              "sorts": [{"propertyName": "createdate", "direction": "DESCENDING"}]
            },
            "assertions": [
              { "field": "dealstage", "operator": "eq", "value": "4443390199" },
              { "field": "hs_is_closed", "operator": "eq", "value": "true" },
              { "field": "hs_is_closed_won", "operator": "eq", "value": "true" }
            ]
          }
        },
        {
          "id": "verify_all_stages_entered",
          "description": "Verify every stage was entered by checking HubSpot date_entered timestamps exist for each stage",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/deals/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "dealname",
                      "operator": "CONTAINS_TOKEN",
                      "value": "Northfield"
                    }
                  ]
                }
              ],
              "properties": [
                "dealname",
                "hs_v2_date_entered_4443390193",
                "hs_v2_date_entered_4443390194",
                "hs_v2_date_entered_4443390195",
                "hs_v2_date_entered_4443390196",
                "hs_v2_date_entered_4443390197",
                "hs_v2_date_entered_4443390198",
                "hs_v2_date_entered_4443390199",
                "createdate"
              ],
              "sorts": [{"propertyName": "createdate", "direction": "DESCENDING"}]
            },
            "assertions": [
              { "field": "hs_v2_date_entered_4443390193", "operator": "not_null", "value": "" },
              { "field": "hs_v2_date_entered_4443390194", "operator": "not_null", "value": "" },
              { "field": "hs_v2_date_entered_4443390195", "operator": "not_null", "value": "" },
              { "field": "hs_v2_date_entered_4443390196", "operator": "not_null", "value": "" },
              { "field": "hs_v2_date_entered_4443390197", "operator": "not_null", "value": "" },
              { "field": "hs_v2_date_entered_4443390198", "operator": "not_null", "value": "" },
              { "field": "hs_v2_date_entered_4443390199", "operator": "not_null", "value": "" }
            ]
          }
        },
        {
          "id": "verify_stages_in_order",
          "description": "Verify the deal passed through stages in chronological order (Discovery -> Follow Up -> ... -> Won)",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/deals/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "dealname",
                      "operator": "CONTAINS_TOKEN",
                      "value": "Northfield"
                    }
                  ]
                }
              ],
              "properties": [
                "dealname",
                "hs_v2_date_entered_4443390193",
                "hs_v2_date_entered_4443390194",
                "hs_v2_date_entered_4443390195",
                "hs_v2_date_entered_4443390196",
                "hs_v2_date_entered_4443390197",
                "hs_v2_date_entered_4443390198",
                "hs_v2_date_entered_4443390199",
                "createdate"
              ],
              "sorts": [{"propertyName": "createdate", "direction": "DESCENDING"}]
            },
            "assertions": [
              {
                "field": "hs_v2_date_entered_4443390193;hs_v2_date_entered_4443390194;hs_v2_date_entered_4443390195;hs_v2_date_entered_4443390196;hs_v2_date_entered_4443390197;hs_v2_date_entered_4443390198;hs_v2_date_entered_4443390199",
                "operator": "timestamps_chronological",
                "value": ""
              }
            ]
          }
        },
        {
          "id": "verify_brand_auto_created",
          "description": "Verify a Brand record was auto-created by the workflow with correct client_name_sync",
          "verify": {
            "method": "search",
            "endpoint": "/crm/v3/objects/0-970/search",
            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "buyer_name",
                      "operator": "CONTAINS_TOKEN",
                      "value": "Northfield"
                    }
                  ]
                }
              ],
              "properties": [
                "buyer_name",
                "client_name_sync",
                "hs_pipeline",
                "hs_pipeline_stage",
                "createdate"
              ],
              "sorts": [{"propertyName": "hs_createdate", "direction": "DESCENDING"}]
            },
            "capture": {
              "brand_id": "$.results[0].id"
            },
            "assertions": [
              { "field": "buyer_name", "operator": "contains", "value": "Northfield" },
              { "field": "client_name_sync", "operator": "eq", "value": "GLUG!" },
              {
                "field": "associations",
                "operator": "associated_to",
                "object_type": "deals",
                "value": "{deal_id}"
              }
            ]
          }
        }
      ],
      "teardown": {
        "description": "Remove test brand, deal, and company (brand first, then parent records)",
        "api_calls": [
          {
            "id": "delete_brand",
