            "search": {
              "filterGroups": [
                {
                  "filters": [
                    {
                      "propertyName": "domain",
                      "operator": "EQ",
                      "value": "testoakwooddeli.com"
                    }
                  ]
                }
              ],
              "properties": [
                "name",
                "domain",
                "city",
                "country",
                "createdate"
              ]
            },
